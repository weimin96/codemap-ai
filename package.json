{
  "name": "@codemapai/codemap-ai",
  "version": "0.2.0",
  "description": "codemap-ai local AI project onboarding workbench with code preview, code graph, flow maps, risk radar, and context-bound Q&A.",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "bin": {
    "codemap-ai": "bin/codemap-ai.js"
  },
  "files": [
    "bin/codemap-ai.js",
    "bin/cli-options.js",
    "server/ai.js",
    "server/ai-errors.js",
    "server/ai-schemas.js",
    "server/analysis-job.js",
    "server/code-graph.js",
    "server/config-crypto.js",
    "server/config-store.js",
    "server/course-builder.js",
    "server/context-enrichment.js",
    "server/context-pack.js",
    "server/document-exporter.js",
    "server/evidence-verifier.js",
    "server/flow-analyzer.js",
    "server/fs-utils.js",
    "server/ignore-rules.js",
    "server/redaction.js",
    "server/repo-map.js",
    "server/report-normalizer.js",
    "server/report-store.js",
    "server/scanner.js",
    "server/server.js",
    "server/symbol-cache.js",
    "server/sqlite-store.js",
    "server/symbol-indexer.js",
    "server/token-counter.js",
    "server/verification.js",
    "web/dist/index.html",
    "web/dist/assets",
    "web/dist/brand/codemap-ai-logo.svg",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node bin/codemap-ai.js . --port 3000",
    "start": "node bin/codemap-ai.js .",
    "build": "vite build web --config web/vite.config.ts",
    "typecheck": "tsc -p web/tsconfig.json --noEmit",
    "test": "node --test server/*.test.js",
    "test:e2e": "playwright test",
    "ci": "node scripts/ci.mjs",
    "ci:full": "node scripts/ci.mjs --e2e --pack",
    "lint": "eslint .",
    "pack:local": "npm pack",
    "release:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.34.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^4.0.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/openai-compatible": "^1.0.0",
    "ai": "^6.0.0",
    "commander": "^14.0.0",
    "express": "^5.0.0",
    "js-tiktoken": "^1.0.20",
    "ollama-ai-provider-v2": "^3.6.0",
    "open": "^10.0.0",
    "typescript": "^5.6.0",
    "zod": "^3.24.0"
  },
  "keywords": [
    "ai",
    "code-atlas",
    "codebase",
    "code-graph",
    "onboarding",
    "project-understanding",
    "rag",
    "react",
    "mermaid",
    "monaco-editor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weimin96/codemap-ai.git"
  },
  "bugs": {
    "url": "https://github.com/weimin96/codemap-ai/issues"
  },
  "homepage": "https://github.com/weimin96/codemap-ai#readme",
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "author": "",
  "license": "MIT"
}
